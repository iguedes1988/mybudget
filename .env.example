# ─────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────
# Local development (docker-compose manages this automatically)
DATABASE_URL="postgresql://localbudget:localbudget_secret@localhost:5432/localbudget"

# PostgreSQL credentials (used only by docker-compose.yml)
POSTGRES_USER=localbudget
POSTGRES_PASSWORD=localbudget_secret
POSTGRES_DB=localbudget

# ─────────────────────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-this"

# Full app URL — used for email links and Server Actions origin
# Production: https://mybudget.apphouse.app
NEXTAUTH_URL="http://localhost:8080"

# ─────────────────────────────────────────────────────────────
# ADMIN SEED CREDENTIALS
# ─────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@mybudget.local"
ADMIN_PASSWORD="Admin@123456"
ADMIN_NAME="Administrator"

# ─────────────────────────────────────────────────────────────
# SMTP — Email delivery (Spacemail / any standard SMTP)
# ─────────────────────────────────────────────────────────────
# Production (Spacemail via Spaceship):
#   SMTP_HOST=mail.spacemail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=no-reply@apphouse.app
#   SMTP_PASS=<set in Hyperlift dashboard — never commit>
#   FROM_EMAIL=no-reply@apphouse.app
#
# If SMTP_HOST is not set, email delivery is skipped (dev mode).
SMTP_HOST=""
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
# Store password as base64 (preferred) or plain text fallback:
# Generate: node -e "console.log(Buffer.from('yourpassword').toString('base64'))"
SMTP_PASS_B64=""
# SMTP_PASS=""   # plain text fallback (not recommended)
FROM_EMAIL=""

# Email address that receives contact form submissions
# Defaults to admin@appbox.app if not set
CONTACT_RECIPIENT_EMAIL=""
